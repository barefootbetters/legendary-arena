# VITE_SERVER_URL — base URL of the boardgame.io game server.
#
# Per-environment source:
#   - Local development: copy this file to `.env` (gitignored) and set the URL.
#     Default fallback in code is http://localhost:8000.
#   - Cloudflare Pages: inject as a build-time environment variable in the
#     Pages project settings; Vite statically inlines it into the client bundle.
#   - Production: TBD (set in the deployment environment before the build runs).
VITE_SERVER_URL=http://localhost:8000
