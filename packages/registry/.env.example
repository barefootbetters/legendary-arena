# Cloudflare R2 credentials (never commit real values — use CI secrets)
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=legendary-arena-assets

# Public base URL for the R2 bucket (set via Cloudflare R2 custom domain)
R2_PUBLIC_URL=https://assets.legendary-arena.com

# Semver string for this data release
DATA_VERSION=1.0.0

# Optional overrides for scripts
INPUT_DIR=data/raw
OUTPUT_FILE=dist/cards.json
INPUT_IMG_DIR=images/raw
OUTPUT_IMG_DIR=images/standard
